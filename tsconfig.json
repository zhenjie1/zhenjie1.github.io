{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "declaration":false,
    "declarationMap":false,
    "checkJs": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "strict": true,
    "lib": ["esnext", "dom"],
    "types": ["vite/client"],
    "plugins": [{ "name": "@vuedx/typescript-plugin-vue" }],
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "typings/*": ["typings/*"],

      "assets/*": ["src/assets/*"],
      "js/*": ["src/assets/js/*"],
      "css/*": ["src/assets/css/*"],
      "images/*": ["src/assets/images/*"],

      "components/*": ["src/components/*"],

      "utils/*": ["utils/*"],

      "page/*": ["src/page/*"],
    }
  },
  "include": [
    "electron/**/*",
    "typings/**/*",
    "utils/**/*",
    "src/**/*.ts", 
    "src/**/*.d.ts", 
    "src/**/*.tsx", "src/**/*.vue"
  ]
}
